---
import BaseLayout from '@layouts/BaseLayout.astro';
import BlogCard from '@components/astro/BlogCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const recentPosts = sortedPosts.slice(0, 6);
---

<BaseLayout
  title="ContentForge"
  description="Developer blog and documentation for Claude Code CLI. Tips, tutorials, and best practices."
>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <!-- Animated gradient background -->
    <div class="absolute inset-0 bg-gradient-to-br from-slate-900 via-slate-900 to-brand-950/30"></div>
    <div class="absolute inset-0 bg-dot-pattern"></div>

    <!-- Floating gradient orbs -->
    <div class="absolute top-1/4 -left-32 w-96 h-96 bg-brand-500/10 rounded-full blur-3xl animate-glow"></div>
    <div class="absolute bottom-1/4 -right-32 w-96 h-96 bg-purple-500/10 rounded-full blur-3xl animate-glow delay-500"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-28 sm:py-36">
      <div class="max-w-3xl animate-fade-in-up">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-brand-500/10 border border-brand-500/20 text-brand-300 text-sm font-medium mb-8">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-brand-500"></span>
          </span>
          Claude Code CLI Guide
        </div>
        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold tracking-tight text-white leading-[1.1]">
          Master
          <span class="text-gradient-animated">
            Claude Code
          </span>
          CLI
        </h1>
        <p class="mt-6 text-xl text-slate-400 leading-relaxed max-w-2xl">
          The definitive resource for Claude Code CLI. Learn hooks, MCP servers, slash commands,
          IDE integrations, and advanced workflows to supercharge your development.
        </p>
        <div class="mt-10 flex flex-wrap gap-4">
          <a
            href="/docs/v2/01-getting-started/introduction"
            class="group inline-flex items-center gap-2 px-7 py-3.5 rounded-xl bg-brand-600 hover:bg-brand-500 text-white font-semibold shadow-lg shadow-brand-600/25 hover:shadow-brand-500/40 hover:shadow-xl transition-all duration-300"
          >
            Read the Docs
            <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
          <a
            href="/blog"
            class="inline-flex items-center gap-2 px-7 py-3.5 rounded-xl border border-slate-600 text-slate-300 font-semibold hover:bg-slate-800 hover:border-slate-500 transition-all duration-300"
          >
            Browse Articles
          </a>
        </div>
      </div>

      <!-- Terminal preview decoration -->
      <div class="hidden lg:block absolute right-8 top-1/2 -translate-y-1/2 w-[420px] animate-fade-in-up delay-300">
        <div class="rounded-xl border border-slate-700/50 bg-black/40 backdrop-blur-sm shadow-2xl overflow-hidden">
          <div class="flex items-center gap-1.5 px-4 py-3 border-b border-slate-700/50">
            <div class="w-3 h-3 rounded-full bg-red-500/60"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500/60"></div>
            <div class="w-3 h-3 rounded-full bg-green-500/60"></div>
            <span class="ml-2 text-xs text-slate-500 font-mono">terminal</span>
          </div>
          <div class="p-4 font-mono text-sm space-y-2">
            <div class="text-slate-500">$ claude</div>
            <div class="text-brand-400">? What would you like to do?</div>
            <div class="text-slate-300 pl-2">› <span class="text-emerald-400">Start a new project</span></div>
            <div class="text-slate-500 pl-2">  Review code</div>
            <div class="text-slate-500 pl-2">  Fix a bug</div>
            <div class="text-slate-500 pl-2">  Write tests</div>
            <div class="mt-2 text-slate-600">──────────────────────────</div>
            <div class="text-slate-400">⌘K to search · /help for commands</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features grid -->
  <section class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
    <!-- Section heading -->
    <div class="text-center mb-14 animate-fade-in-up">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">Everything you need to master</h2>
      <p class="text-lg text-slate-400 max-w-2xl mx-auto">Deep dives into the most powerful features of Claude Code CLI</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- Hooks -->
      <a href="/blog/claude-code-hooks-guide" class="group card-glow p-6 animate-fade-in-up delay-100">
        <div class="relative">
          <div class="w-12 h-12 rounded-xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-400 mb-5 group-hover:scale-110 group-hover:shadow-lg group-hover:shadow-emerald-500/20 transition-all duration-300">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-white mb-2 group-hover:text-emerald-400 transition-colors">Hooks & Automation</h3>
          <p class="text-sm text-slate-400 leading-relaxed mb-4">Pre-commit hooks, post-commit automation, and custom event handlers to streamline your workflow.</p>
          <span class="inline-flex items-center gap-1.5 text-sm text-emerald-400 opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300">
            Read more
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
          </span>
        </div>
      </a>

      <!-- MCP -->
      <a href="/blog/mcp-servers-deep-dive" class="group card-glow p-6 animate-fade-in-up delay-200">
        <div class="relative">
          <div class="w-12 h-12 rounded-xl bg-purple-500/10 border border-purple-500/20 flex items-center justify-center text-purple-400 mb-5 group-hover:scale-110 group-hover:shadow-lg group-hover:shadow-purple-500/20 transition-all duration-300">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-white mb-2 group-hover:text-purple-400 transition-colors">MCP Servers</h3>
          <p class="text-sm text-slate-400 leading-relaxed mb-4">Build and connect custom MCP servers to extend Claude Code with project-specific tools and context.</p>
          <span class="inline-flex items-center gap-1.5 text-sm text-purple-400 opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300">
            Read more
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
          </span>
        </div>
      </a>

      <!-- IDE -->
      <a href="/blog/ide-integrations-vscode-jetbrains" class="group card-glow p-6 animate-fade-in-up delay-300">
        <div class="relative">
          <div class="w-12 h-12 rounded-xl bg-amber-500/10 border border-amber-500/20 flex items-center justify-center text-amber-400 mb-5 group-hover:scale-110 group-hover:shadow-lg group-hover:shadow-amber-500/20 transition-all duration-300">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-white mb-2 group-hover:text-amber-400 transition-colors">IDE Integrations</h3>
          <p class="text-sm text-slate-400 leading-relaxed mb-4">Seamlessly use Claude Code in VS Code, JetBrains, and terminal environments for maximum productivity.</p>
          <span class="inline-flex items-center gap-1.5 text-sm text-amber-400 opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300">
            Read more
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
          </span>
        </div>
      </a>
    </div>
  </section>

  <!-- Recent Posts -->
  {recentPosts.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <div class="flex items-center justify-between mb-10">
        <div>
          <h2 class="text-3xl font-bold text-white mb-2">Latest Articles</h2>
          <p class="text-slate-400">Deep dives and tutorials for Claude Code CLI</p>
        </div>
        <a href="/blog" class="hidden sm:inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-medium text-brand-400 hover:text-brand-300 border border-brand-500/20 hover:border-brand-500/40 hover:bg-brand-500/5 transition-all">
          View all
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {recentPosts.map((post) => (
          <BlogCard
            id={post.id}
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category}
            tags={post.data.tags}
            body={post.body}
            featured={post.data.featured}
          />
        ))}
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="relative rounded-2xl overflow-hidden">
      <!-- Gradient background -->
      <div class="absolute inset-0 bg-gradient-to-r from-brand-600 via-purple-600 to-brand-600 animate-gradient"></div>
      <div class="absolute inset-0 bg-dot-pattern opacity-10"></div>

      <div class="relative p-10 sm:p-16 text-center text-white">
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">Ready to level up?</h2>
        <p class="text-lg text-white/80 mb-8 max-w-2xl mx-auto">
          Dive into the documentation and discover everything Claude Code CLI can do for your development workflow.
        </p>
        <a
          href="/docs/v2/01-getting-started/introduction"
          class="group inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-white text-brand-700 font-bold hover:bg-brand-50 transition-all shadow-lg hover:shadow-xl hover:scale-[1.02]"
        >
          Get Started
          <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

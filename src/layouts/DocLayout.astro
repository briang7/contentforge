---
import BaseLayout from './BaseLayout.astro';
import DocSidebar from '@components/astro/DocSidebar.astro';
import TOC from '@components/astro/TOC.astro';
import ReadAloud from '@components/react/ReadAloud';
import type { MarkdownHeading } from 'astro';

interface Props {
  title: string;
  description: string;
  version: string;
  currentId: string;
  headings: MarkdownHeading[];
  editUrl?: string;
  prevDoc?: { id: string; title: string };
  nextDoc?: { id: string; title: string };
}

const { title, description, version, currentId, headings, editUrl, prevDoc, nextDoc } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="max-w-[90rem] mx-auto flex">
    <!-- Sidebar -->
    <aside class="hidden lg:block w-72 shrink-0 border-r border-slate-800">
      <div class="sticky top-16 h-[calc(100vh-4rem)] overflow-y-auto p-6">
        <DocSidebar version={version} currentId={currentId} />
      </div>
    </aside>

    <!-- Mobile sidebar toggle -->
    <input type="checkbox" id="sidebar-toggle" class="hidden peer" />
    <label
      for="sidebar-toggle"
      class="lg:hidden fixed bottom-4 left-4 z-40 p-3 rounded-full bg-brand-600 text-white shadow-lg shadow-brand-500/25 cursor-pointer hover:bg-brand-500 transition-all duration-200"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </label>
    <div class="fixed inset-0 z-30 bg-black/60 backdrop-blur-sm hidden peer-checked:block lg:hidden" onclick="document.getElementById('sidebar-toggle').checked = false"></div>
    <aside class="fixed inset-y-0 left-0 z-30 w-72 bg-slate-900 border-r border-slate-800 transform -translate-x-full peer-checked:translate-x-0 transition-transform duration-300 lg:hidden overflow-y-auto p-6">
      <DocSidebar version={version} currentId={currentId} />
    </aside>

    <!-- Main content -->
    <div class="flex-1 min-w-0">
      <article class="max-w-4xl mx-auto px-6 py-12">
        <header class="mb-8 animate-fade-in-up">
          <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-white">
            {title}
          </h1>
          <p class="mt-2 text-lg text-slate-400">
            {description}
          </p>
        </header>

        <ReadAloud client:only="react" />

        <div class="flex gap-12">
          <div class="flex-1 min-w-0 prose dark:prose-invert" data-pagefind-body>
            <slot />
          </div>

          {headings.length > 0 && (
            <aside class="hidden xl:block w-56 shrink-0">
              <div class="sticky top-24">
                <TOC headings={headings} />
              </div>
            </aside>
          )}
        </div>

        <!-- Edit on GitHub -->
        {editUrl && (
          <div class="mt-10 pt-6 border-t border-slate-800">
            <a
              href={editUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm text-slate-500 hover:text-brand-400 transition-colors duration-200"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
              </svg>
              Edit this page on GitHub
            </a>
          </div>
        )}

        <!-- Previous / Next -->
        <nav class="mt-8 pt-6 border-t border-slate-800">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {prevDoc ? (
              <a href={`/docs/${prevDoc.id}`} class="group flex items-center gap-3 p-4 rounded-xl border border-slate-800 hover:border-brand-500/30 hover:bg-brand-500/5 transition-all duration-200">
                <svg class="w-5 h-5 text-slate-600 group-hover:text-brand-400 group-hover:-translate-x-1 transition-all shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 17l-5-5m0 0l5-5m-5 5h12" /></svg>
                <div>
                  <span class="text-xs text-slate-500 block mb-0.5">Previous</span>
                  <span class="text-sm text-slate-300 group-hover:text-brand-400 transition-colors">{prevDoc.title}</span>
                </div>
              </a>
            ) : <div />}
            {nextDoc ? (
              <a href={`/docs/${nextDoc.id}`} class="group flex items-center gap-3 p-4 rounded-xl border border-slate-800 hover:border-brand-500/30 hover:bg-brand-500/5 transition-all duration-200 text-right sm:justify-end">
                <div>
                  <span class="text-xs text-slate-500 block mb-0.5">Next</span>
                  <span class="text-sm text-slate-300 group-hover:text-brand-400 transition-colors">{nextDoc.title}</span>
                </div>
                <svg class="w-5 h-5 text-slate-600 group-hover:text-brand-400 group-hover:translate-x-1 transition-all shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
              </a>
            ) : <div />}
          </div>
        </nav>
      </article>
    </div>
  </div>
</BaseLayout>

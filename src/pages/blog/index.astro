---
import BaseLayout from '@layouts/BaseLayout.astro';
import BlogCard from '@components/astro/BlogCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const categories = [...new Set(allPosts.map((p) => p.data.category))].sort();
const tags = [...new Set(allPosts.flatMap((p) => p.data.tags))].sort();

const featured = sortedPosts.find((p) => p.data.featured);
const posts = featured ? sortedPosts.filter((p) => p !== featured) : sortedPosts;
---

<BaseLayout
  title="Blog"
  description="Articles, tutorials, and tips for mastering Claude Code CLI."
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Header -->
    <div class="mb-12 animate-fade-in-up">
      <h1 class="text-4xl font-extrabold text-white mb-3">Blog</h1>
      <p class="text-lg text-slate-400">
        Tutorials, tips, and deep dives into Claude Code CLI features.
      </p>
    </div>

    <!-- Featured post -->
    {featured && (
      <a
        href={`/blog/${featured.id}`}
        class="group relative block mb-12 rounded-2xl overflow-hidden transition-all duration-500 hover:-translate-y-0.5"
      >
        <!-- Gradient border -->
        <div class="absolute inset-0 rounded-2xl bg-gradient-to-r from-brand-500/40 via-purple-500/20 to-brand-500/40 p-[1px] group-hover:from-brand-500/60 group-hover:via-purple-500/40 group-hover:to-brand-500/60 transition-all duration-500">
          <div class="h-full w-full rounded-[15px] bg-slate-900"></div>
        </div>

        <div class="relative p-8 sm:p-10">
          <!-- Subtle gradient overlay -->
          <div class="absolute inset-0 bg-gradient-to-br from-brand-500/5 to-purple-500/5 rounded-2xl"></div>

          <div class="relative">
            <div class="flex items-center gap-3 mb-4">
              <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-brand-500/10 text-brand-400 border border-brand-500/20">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                Featured
              </span>
              <span class="text-sm text-slate-500">
                {featured.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </span>
            </div>
            <h2 class="text-2xl sm:text-3xl font-bold text-white group-hover:text-brand-400 transition-colors duration-300 mb-3">
              {featured.data.title}
            </h2>
            <p class="text-slate-400 leading-relaxed max-w-3xl mb-4">
              {featured.data.description}
            </p>
            <span class="inline-flex items-center gap-1.5 text-sm text-brand-400 opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300">
              Read article
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
            </span>
          </div>
        </div>
      </a>
    )}

    <!-- Category filter -->
    <div class="flex flex-wrap gap-2 mb-10">
      <a
        href="/blog"
        class="px-4 py-1.5 rounded-full text-sm font-medium bg-brand-500/20 text-brand-300 border border-brand-500/30 hover:bg-brand-500/30 transition-all"
      >
        All
      </a>
      {categories.map((cat) => (
        <a
          href={`/blog/category/${cat}`}
          class="px-4 py-1.5 rounded-full text-sm font-medium text-slate-400 border border-slate-700 hover:border-slate-500 hover:text-slate-200 hover:bg-slate-800/50 transition-all"
        >
          {cat.replace(/-/g, ' ')}
        </a>
      ))}
    </div>

    <!-- Posts grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map((post) => (
        <BlogCard
          id={post.id}
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          category={post.data.category}
          tags={post.data.tags}
          body={post.body}
        />
      ))}
    </div>

    <!-- Tags -->
    <div class="mt-16 pt-8 border-t border-slate-800">
      <h2 class="text-lg font-bold text-white mb-5">Browse by tag</h2>
      <div class="flex flex-wrap gap-2">
        {tags.map((tag) => (
          <a
            href={`/blog/tag/${tag}`}
            class="px-3 py-1.5 text-sm rounded-lg text-slate-400 bg-slate-800/50 border border-slate-700/50 hover:border-brand-500/30 hover:text-brand-400 hover:bg-brand-500/5 transition-all duration-200"
          >
            #{tag}
          </a>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

---
const year = new Date().getFullYear();
---

<footer class="relative border-t border-slate-800" data-pagefind-ignore>
  <!-- Gradient accent line (matching header) -->
  <div class="h-[1px] bg-gradient-to-r from-transparent via-brand-500/30 to-transparent"></div>

  <div class="bg-slate-900/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-10">
        <!-- About -->
        <div>
          <div class="flex items-center gap-2.5 mb-4">
            <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-brand-500 to-purple-600 flex items-center justify-center text-white font-bold text-xs">
              CF
            </div>
            <span class="font-bold text-white">ContentForge</span>
          </div>
          <p class="text-sm text-slate-400 leading-relaxed">
            A developer blog and documentation platform covering Claude Code CLI tips, tricks, and best practices.
          </p>
        </div>

        <!-- Links -->
        <div>
          <h3 class="font-semibold text-sm text-slate-300 mb-4 uppercase tracking-wider">Resources</h3>
          <ul class="space-y-2.5 text-sm">
            <li><a href="/blog" class="text-slate-400 hover:text-brand-400 transition-colors duration-200">Blog</a></li>
            <li><a href="/docs/v2/01-getting-started/introduction" class="text-slate-400 hover:text-brand-400 transition-colors duration-200">Documentation</a></li>
            <li><a href="/rss.xml" class="text-slate-400 hover:text-brand-400 transition-colors duration-200">RSS Feed</a></li>
          </ul>
        </div>

        <!-- Social -->
        <div>
          <h3 class="font-semibold text-sm text-slate-300 mb-4 uppercase tracking-wider">Connect</h3>
          <ul class="space-y-2.5 text-sm">
            <li>
              <a href="https://github.com/briang7/contentforge" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-slate-400 hover:text-brand-400 transition-colors duration-200">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" /></svg>
                GitHub
              </a>
            </li>
            <li>
              <a href="https://github.com/briang7" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-slate-400 hover:text-brand-400 transition-colors duration-200">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                Portfolio
              </a>
            </li>
          </ul>
        </div>
      </div>

      <div class="mt-12 pt-6 border-t border-slate-800 flex flex-col sm:flex-row justify-between items-center gap-4">
        <p class="text-sm text-slate-500">
          &copy; {year} ContentForge. Built with Astro.
        </p>
        <div class="flex items-center gap-3 text-xs text-slate-600">
          <span class="flex items-center gap-1.5">
            <span class="w-1.5 h-1.5 rounded-full bg-brand-500"></span>
            Astro 5
          </span>
          <span class="flex items-center gap-1.5">
            <span class="w-1.5 h-1.5 rounded-full bg-cyan-500"></span>
            React
          </span>
          <span class="flex items-center gap-1.5">
            <span class="w-1.5 h-1.5 rounded-full bg-orange-500"></span>
            Svelte
          </span>
          <span class="flex items-center gap-1.5">
            <span class="w-1.5 h-1.5 rounded-full bg-teal-500"></span>
            Tailwind
          </span>
        </div>
      </div>
    </div>
  </div>
</footer>

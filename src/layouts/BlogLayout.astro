---
import BaseLayout from './BaseLayout.astro';
import TOC from '@components/astro/TOC.astro';
import ReadAloud from '@components/react/ReadAloud';
import type { MarkdownHeading } from 'astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  author: string;
  readingTime: string;
  category: string;
  tags: string[];
  headings: MarkdownHeading[];
  prevPost?: { id: string; title: string };
  nextPost?: { id: string; title: string };
  series?: { name: string; posts: { id: string; title: string; current: boolean }[] };
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  author,
  readingTime,
  category,
  tags,
  headings,
  prevPost,
  nextPost,
  series,
} = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdated = updatedDate?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const categoryColors: Record<string, string> = {
  'getting-started': 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20',
  'tips-and-tricks': 'bg-amber-500/10 text-amber-400 border-amber-500/20',
  'best-practices': 'bg-cyan-500/10 text-cyan-400 border-cyan-500/20',
  'integrations': 'bg-purple-500/10 text-purple-400 border-purple-500/20',
  'advanced': 'bg-red-500/10 text-red-400 border-red-500/20',
  'tutorials': 'bg-brand-500/10 text-brand-400 border-brand-500/20',
};

const catClass = categoryColors[category] || categoryColors['tutorials'];
---

<BaseLayout
  title={title}
  description={description}
  type="article"
  publishedTime={pubDate.toISOString()}
  modifiedTime={updatedDate?.toISOString()}
  author={author}
  tags={tags}
>
  <article class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Header -->
    <header class="max-w-3xl mx-auto mb-10 animate-fade-in-up">
      <div class="flex items-center gap-3 mb-4 text-sm">
        <a
          href={`/blog/category/${category}`}
          class:list={['inline-block px-3 py-1 rounded-full font-medium border transition-all hover:opacity-80', catClass]}
        >
          {category.replace(/-/g, ' ')}
        </a>
        <span class="text-slate-600">&middot;</span>
        <time datetime={pubDate.toISOString()} class="text-slate-500">
          {formattedDate}
        </time>
        <span class="text-slate-600">&middot;</span>
        <span class="flex items-center gap-1 text-slate-500">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          {readingTime}
        </span>
      </div>

      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight mb-4 text-white leading-tight">
        {title}
      </h1>

      <p class="text-xl text-slate-400 leading-relaxed">
        {description}
      </p>

      {updatedDate && (
        <p class="mt-4 text-sm text-slate-500 italic">
          Updated {formattedUpdated}
        </p>
      )}
    </header>

    <!-- Read Aloud -->
    <ReadAloud client:only="react" />

    <!-- Series nav -->
    {series && (
      <nav class="max-w-3xl mx-auto mb-8 rounded-xl overflow-hidden">
        <div class="bg-gradient-to-r from-brand-500/10 to-purple-500/10 border border-brand-500/20 rounded-xl p-5">
          <p class="text-sm font-semibold text-slate-300 mb-3 flex items-center gap-2">
            <svg class="w-4 h-4 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
            Series: {series.name}
          </p>
          <ol class="list-decimal list-inside space-y-1.5 text-sm">
            {series.posts.map((post) => (
              <li class={post.current ? 'font-bold text-brand-400' : 'text-slate-400'}>
                {post.current ? (
                  <span>{post.title}</span>
                ) : (
                  <a href={`/blog/${post.id}`} class="text-brand-400 hover:underline">
                    {post.title}
                  </a>
                )}
              </li>
            ))}
          </ol>
        </div>
      </nav>
    )}

    <!-- Content + TOC -->
    <div class="relative max-w-3xl mx-auto">
      <div class="prose dark:prose-invert" data-pagefind-body>
        <slot />
      </div>

      <!-- Table of Contents (starts centered, sticks below nav) -->
      {headings.length > 0 && (
        <aside class="hidden xl:block w-48 max-h-[calc(100vh-8rem)] overflow-y-auto transition-[top] duration-300" id="toc-aside">
          <TOC headings={headings} />
        </aside>
      )}
    </div>

    <!-- Tags -->
    {tags.length > 0 && (
      <div class="max-w-3xl mx-auto mt-10 pt-6 border-t border-slate-800">
        <div class="flex flex-wrap gap-2">
          {tags.map((tag) => (
            <a
              href={`/blog/tag/${tag}`}
              class="px-3 py-1.5 text-sm rounded-lg text-slate-400 bg-slate-800/50 border border-slate-700/50 hover:border-brand-500/30 hover:text-brand-400 hover:bg-brand-500/5 transition-all duration-200"
            >
              #{tag}
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Previous / Next -->
    <nav class="max-w-3xl mx-auto mt-10 pt-6 border-t border-slate-800">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {prevPost ? (
          <a href={`/blog/${prevPost.id}`} class="group flex items-center gap-3 p-4 rounded-xl border border-slate-800 hover:border-brand-500/30 hover:bg-brand-500/5 transition-all duration-200">
            <svg class="w-5 h-5 text-slate-600 group-hover:text-brand-400 group-hover:-translate-x-1 transition-all shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 17l-5-5m0 0l5-5m-5 5h12" /></svg>
            <div class="min-w-0">
              <span class="text-xs text-slate-500 block mb-0.5">Previous</span>
              <span class="text-sm text-slate-300 group-hover:text-brand-400 transition-colors line-clamp-1">{prevPost.title}</span>
            </div>
          </a>
        ) : <div />}
        {nextPost ? (
          <a href={`/blog/${nextPost.id}`} class="group flex items-center gap-3 p-4 rounded-xl border border-slate-800 hover:border-brand-500/30 hover:bg-brand-500/5 transition-all duration-200 text-right sm:justify-end">
            <div class="min-w-0">
              <span class="text-xs text-slate-500 block mb-0.5">Next</span>
              <span class="text-sm text-slate-300 group-hover:text-brand-400 transition-colors line-clamp-1">{nextPost.title}</span>
            </div>
            <svg class="w-5 h-5 text-slate-600 group-hover:text-brand-400 group-hover:translate-x-1 transition-all shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
          </a>
        ) : <div />}
      </div>
    </nav>
  </article>

  <script>
    function initTOCPosition() {
      const toc = document.getElementById('toc-aside');
      const content = document.querySelector('.prose[data-pagefind-body]');
      if (!toc || !content) return;

      // Calculate the vertical center start position
      const tocHeight = toc.offsetHeight;
      const centerY = (window.innerHeight - tocHeight) / 2;
      const stickyTop = 96; // 6rem = below nav

      // Position horizontally to the right of content
      function setLeft() {
        const rect = content.getBoundingClientRect();
        toc.style.left = `${rect.right + 48}px`;
      }

      // Scroll handler: start at center, stick at top
      function onScroll() {
        const scrollY = window.scrollY;
        const threshold = centerY - stickyTop;

        if (scrollY < threshold) {
          // Before threshold: fixed at vertical center
          toc.style.position = 'fixed';
          toc.style.top = `${centerY}px`;
        } else {
          // After threshold: fixed below nav
          toc.style.position = 'fixed';
          toc.style.top = `${stickyTop}px`;
        }
        setLeft();
      }

      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll);
    }

    initTOCPosition();
    document.addEventListener('astro:after-swap', initTOCPosition);
  </script>
</BaseLayout>

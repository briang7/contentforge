---
import BaseLayout from '@layouts/BaseLayout.astro';
import BlogCard from '@components/astro/BlogCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const tags = [...new Set(posts.flatMap((p) => p.data.tags))];
  return tags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter((p) => p.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout
  title={`#${tag}`}
  description={`Articles tagged with "${tag}" about Claude Code CLI.`}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8">
      <a href="/blog" class="text-sm text-brand-600 dark:text-brand-400 hover:underline mb-2 inline-block">&larr; All posts</a>
      <h1 class="text-3xl font-bold text-slate-900 dark:text-white">#{tag}</h1>
      <p class="text-slate-600 dark:text-slate-400 mt-2">{posts.length} article{posts.length !== 1 ? 's' : ''}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map((post) => (
        <BlogCard
          id={post.id}
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          category={post.data.category}
          tags={post.data.tags}
          body={post.body}
        />
      ))}
    </div>
  </div>
</BaseLayout>

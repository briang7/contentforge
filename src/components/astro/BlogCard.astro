---
import { getReadingTime } from '@utils/reading-time';

interface Props {
  id: string;
  title: string;
  description: string;
  pubDate: Date;
  category: string;
  tags: string[];
  body?: string;
  featured?: boolean;
}

const { id, title, description, pubDate, category, tags, body, featured } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const readingTime = getReadingTime(body);

const categoryColors: Record<string, string> = {
  'getting-started': 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20',
  'tips-and-tricks': 'bg-amber-500/10 text-amber-400 border-amber-500/20',
  'best-practices': 'bg-cyan-500/10 text-cyan-400 border-cyan-500/20',
  'integrations': 'bg-purple-500/10 text-purple-400 border-purple-500/20',
  'advanced': 'bg-red-500/10 text-red-400 border-red-500/20',
  'tutorials': 'bg-brand-500/10 text-brand-400 border-brand-500/20',
};

const catClass = categoryColors[category] || categoryColors['tutorials'];
---

<article class="group relative rounded-xl overflow-hidden transition-all duration-300 hover:-translate-y-1">
  <!-- Gradient border effect -->
  <div class="absolute inset-0 rounded-xl bg-gradient-to-b from-slate-700/50 to-slate-700/20 p-[1px] transition-all duration-500 group-hover:from-brand-500/50 group-hover:to-purple-500/30">
    <div class="h-full w-full rounded-[11px] bg-slate-900"></div>
  </div>

  <a href={`/blog/${id}`} class="relative block p-6">
    <!-- Category + Featured -->
    <div class="flex items-center gap-2 mb-3">
      <span class:list={['inline-block px-2.5 py-0.5 rounded-full text-xs font-medium border', catClass]}>
        {category.replace(/-/g, ' ')}
      </span>
      {featured && (
        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-amber-500/10 text-amber-400 border border-amber-500/20">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
          Featured
        </span>
      )}
    </div>

    <!-- Title -->
    <h3 class="text-lg font-bold text-white group-hover:text-brand-400 transition-colors duration-300 line-clamp-2 mb-2">
      {title}
    </h3>

    <!-- Description -->
    <p class="text-sm text-slate-400 line-clamp-3 mb-4 leading-relaxed">
      {description}
    </p>

    <!-- Meta -->
    <div class="flex items-center justify-between text-xs text-slate-500 mb-3">
      <time datetime={pubDate.toISOString()}>{formattedDate}</time>
      <span class="flex items-center gap-1">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        {readingTime}
      </span>
    </div>

    <!-- Tags -->
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5 pt-3 border-t border-slate-800">
        {tags.slice(0, 3).map((tag) => (
          <span class="text-xs text-slate-500 bg-slate-800/50 px-2 py-0.5 rounded-md">
            #{tag}
          </span>
        ))}
        {tags.length > 3 && (
          <span class="text-xs text-slate-600 px-1">+{tags.length - 3}</span>
        )}
      </div>
    )}

    <!-- Read more arrow (appears on hover) -->
    <div class="absolute bottom-6 right-6 opacity-0 translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300">
      <svg class="w-5 h-5 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
    </div>
  </a>
</article>

---
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filteredHeadings.length > 0 && (
  <nav class="toc" aria-label="Table of contents">
    <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-3 flex items-center gap-2">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" /></svg>
      On this page
    </p>
    <ul class="space-y-1 text-sm border-l border-slate-800">
      {filteredHeadings.map((heading) => (
        <li>
          <a
            href={`#${heading.slug}`}
            class:list={[
              'block transition-all duration-200 border-l-2 -ml-px',
              heading.depth === 2 ? 'pl-4 border-transparent' : 'pl-8 border-transparent text-[13px]',
              'text-slate-500 hover:text-brand-400 hover:border-brand-500',
            ]}
            data-toc-link
            data-heading-slug={heading.slug}
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

<script>
  function initTOC() {
    const links = document.querySelectorAll('[data-toc-link]');
    if (!links.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            links.forEach((link) => {
              link.classList.remove('!text-brand-400', '!border-brand-500', 'font-medium');
              link.classList.add('border-transparent');
            });
            const activeLink = document.querySelector(
              `[data-heading-slug="${entry.target.id}"]`
            );
            if (activeLink) {
              activeLink.classList.add('!text-brand-400', '!border-brand-500', 'font-medium');
              activeLink.classList.remove('border-transparent');
            }
          }
        }
      },
      { rootMargin: '-80px 0px -70% 0px', threshold: 0 }
    );

    document.querySelectorAll('h2[id], h3[id]').forEach((heading) => {
      observer.observe(heading);
    });
  }

  initTOC();
  document.addEventListener('astro:after-swap', initTOC);
</script>

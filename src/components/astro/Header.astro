---
const pathname = Astro.url.pathname;

const navLinks = [
  { href: '/blog', label: 'Blog' },
  { href: '/docs/v2/01-getting-started/introduction', label: 'Docs' },
];
---

<header class="sticky top-0 z-20 border-b border-slate-700/50" data-pagefind-ignore>
  <!-- Gradient accent line -->
  <div class="h-[2px] bg-gradient-to-r from-brand-500 via-purple-500 to-brand-500"></div>

  <div class="bg-slate-900/80 backdrop-blur-xl">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2.5 group">
          <div class="relative w-8 h-8 rounded-lg bg-gradient-to-br from-brand-500 to-purple-600 flex items-center justify-center text-white font-bold text-sm group-hover:scale-110 group-hover:shadow-lg group-hover:shadow-brand-500/30 transition-all duration-300">
            CF
          </div>
          <span class="font-bold text-lg text-white">ContentForge</span>
        </a>

        <!-- Desktop nav -->
        <nav class="hidden sm:flex items-center gap-1">
          {navLinks.map(({ href, label }) => (
            <a
              href={href}
              class:list={[
                'relative px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200',
                pathname.startsWith(href)
                  ? 'text-brand-300 bg-brand-500/10'
                  : 'text-slate-400 hover:text-white hover:bg-slate-800',
              ]}
            >
              {label}
              {pathname.startsWith(href) && (
                <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-4 h-0.5 rounded-full bg-brand-500"></span>
              )}
            </a>
          ))}
        </nav>

        <!-- Right side -->
        <div class="flex items-center gap-2">
          <!-- Search button -->
          <button
            id="search-trigger"
            class="flex items-center gap-2 px-3 py-1.5 rounded-lg border border-slate-700 text-sm text-slate-400 hover:border-slate-500 hover:text-slate-200 hover:bg-slate-800/50 transition-all duration-200"
            aria-label="Search"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <span class="hidden sm:inline">Search</span>
            <kbd class="hidden sm:inline-flex items-center gap-0.5 px-1.5 py-0.5 rounded bg-slate-800 border border-slate-700 text-xs font-mono text-slate-500">
              <span class="text-xs">Ctrl</span>K
            </kbd>
          </button>

          <!-- GitHub link -->
          <a
            href="https://github.com/briang7/contentforge"
            target="_blank"
            rel="noopener noreferrer"
            class="p-2 rounded-lg text-slate-400 hover:text-white hover:bg-slate-800 transition-all duration-200"
            aria-label="GitHub"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
            </svg>
          </a>

          <!-- Mobile menu -->
          <details class="sm:hidden relative">
            <summary class="p-2 rounded-lg text-slate-400 hover:bg-slate-800 cursor-pointer list-none">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
            </summary>
            <nav class="absolute right-0 top-full mt-2 w-48 py-2 bg-slate-800 rounded-xl shadow-xl border border-slate-700 overflow-hidden">
              {navLinks.map(({ href, label }) => (
                <a
                  href={href}
                  class="block px-4 py-2.5 text-sm text-slate-300 hover:bg-slate-700 hover:text-white transition-colors"
                >
                  {label}
                </a>
              ))}
            </nav>
          </details>
        </div>
      </div>
    </div>
  </div>
</header>
